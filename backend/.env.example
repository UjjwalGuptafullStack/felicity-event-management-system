# Server Configuration
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/convene-events

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRY=7d

# Bcrypt
BCRYPT_ROUNDS=10

# Institution branding (optional) — labels "affiliated" participants (e.g. students of a
# specific college) vs. the general public. Comma-separate multiple domains.
# Leave INSTITUTION_EMAIL_DOMAINS empty to disable the affiliated/general distinction.
INSTITUTION_NAME=Your Institution
INSTITUTION_EMAIL_DOMAINS=

# Domain used for auto-generated organizer login emails (e.g. tech-club@<domain>)
ORGANIZER_EMAIL_DOMAIN=clubs.convene.app

# Admin Bootstrap (Backend-only, never exposed via API)
ADMIN_EMAIL=admin@convene.app
ADMIN_PASSWORD=SecureAdminPassword123!
ADMIN_FIRST_NAME=System
ADMIN_LAST_NAME=Administrator

# Public app URL (used to build links in emails, e.g. password reset links)
APP_URL=http://localhost:5173

# Email / SMTP (leave empty to log credentials to console in dev mode)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=Convene <noreply@convene.app>
