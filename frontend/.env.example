# Backend API base URL — set this in your hosting provider's environment variable settings
VITE_API_BASE_URL=https://your-backend-url.com

# Institution branding (optional) — must mirror the backend's INSTITUTION_NAME /
# INSTITUTION_EMAIL_DOMAINS env vars. Leave the domains empty to disable the
# affiliated/general participant distinction on the registration form.
VITE_INSTITUTION_NAME=Your Institution
VITE_INSTITUTION_EMAIL_DOMAINS=
